        },
        {
          "id": "c8f277ec-ba6a-4db3-a777-969d42aa13e9",
          "text": "Manahimik tayo sandali habang isinasaalang-alang natin ang ating mga kasalanan sa harapan ng Diyos.",
          "type": "verbal_cue",
          "rubric": false,
          "visibility": "leader_only"
