    {
      "id": "6a573ced-7912-4227-b5e9-55798f4af464",
      "liturgy_id": "774b3e8e-6aa8-4c91-b7b7-176c5ed30d62",
      "template_section_index": 5,
      "items": [
        {
          "id": "93fa279e-67a7-47a3-9783-7e073ebbbdd7",
